# Node.js and Electron development exclusions

# logs
logs/
*.log
npm-debug.log*

# runtime data
pids/
*.pid
*.seed

# directory for instrumented libs generated by jscoverage/JSCover
lib-cov/

# coverage directory used by tools like istanbul
coverage/

# dependency directory
node_modules/

# OPTIONAL: dotenv environment variable file
.env

# build output
dist/
build/

# Electron
# Ignore Electron build directories
electron-builder.json
electron-*..*.json

# Ignore macOS specific files
*.DS_Store

# yarn.lock ignored — but package-lock.json IS tracked for reproducible installs
dist-app/
out/
*.dmg
